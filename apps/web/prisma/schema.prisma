generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  users         User[]
  clients       Client[]
  mediaFormats  MediaFormat[]
}

model User {
  id        String    @id @default(cuid())
  tenantId  String
  name      String?
  email     String    @unique
  password  String
  role      String    @default("ADMIN")
  blocked   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  accounts  Account[]
  sessions  Session[]
  deliveries    Delivery[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Client {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  slug      String?
  contact   String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  campaigns Campaign[]
}

model Campaign {
  id              String             @id @default(cuid())
  name            String
  code            String?            @db.VarChar(64)
  clientId        String
  status          String             @default("STANDBY")
  psdUrl          String?            @db.Text
  psdName         String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assets          CampaignAsset[]
  keyVision       KeyVision?
  pieces          Piece[]
  deliveries      Delivery[]
  smartObjects    SmartObjectFile[]
}

model CampaignAsset {
  id              String           @id @default(cuid())
  campaignId      String
  type            String           @default("TEXT")
  label           String
  content         String?          @db.LongText
  value           String?          @db.Text
  imageUrl        String?          @db.LongText
  // lastOverride: JSON com o ultimo template visual aplicado na MATRIZ
  // (cor, fonte, tamanho, etc). Quando o asset e adicionado de novo no canvas
  // ou via swap, vem com esse template. Pecas nao atualizam esse campo.
  lastOverride    Json?
  order           Int              @default(0)
  posX            Float            @default(100)
  posY            Float            @default(100)
  scaleX          Float            @default(1)
  scaleY          Float            @default(1)
  rotation        Float            @default(0)
  width           Int              @default(600)
  visible         Boolean          @default(true)
  smartObjectId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  campaign        Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  smartObject     SmartObjectFile? @relation(fields: [smartObjectId], references: [id], onDelete: SetNull)

  @@index([smartObjectId])
}

// Smart Object embeddado em PSD (linkedFile). Preserva os bytes originais
// pra round-trip ZZOSY → Photoshop → ZZOSY sem perda. 1 SO pode ser reusado
// por varios CampaignAsset (mesmo logo em multiplos layers, por exemplo).
model SmartObjectFile {
  id            String          @id @default(cuid())
  campaignId    String
  guid          String          @db.VarChar(64)
  filePath      String          @db.LongText
  mime          String          @db.VarChar(100)
  originalName  String          @db.VarChar(500)
  sizeBytes     Int
  width         Int?
  height        Int?
  createdAt     DateTime        @default(now())
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assets        CampaignAsset[]

  @@index([campaignId])
  @@index([guid])
}

model KeyVision {
  id           String   @id @default(cuid())
  campaignId   String   @unique
  data         String?  @db.LongText
  bgColor      String   @default("#ffffff")
  layers       String?  @db.LongText
  width        Int      @default(1920)
  height       Int      @default(1080)
  thumbnailUrl String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Piece {
  id            String         @id @default(cuid())
  campaignId    String
  mediaFormatId String?
  name          String?
  segment       String?        @db.VarChar(255)
  copy          String?        @db.LongText
  status        String         @default("STANDBY")
  data          String?        @db.LongText
  imageUrl      String?        @db.LongText
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deliveries    DeliveryPiece[]
}

model Delivery {
  id            String          @id @default(cuid())
  campaignId    String
  name          String?
  status        String          @default("PENDING")
  notes         String?         @db.Text
  zipUrl        String?         @db.Text
  zipSize       Int?
  deliveredById String?
  formats       String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deliveredBy   User?           @relation(fields: [deliveredById], references: [id])
  files         DeliveryFile[]
  pieces        DeliveryPiece[]
}

model DeliveryFile {
  id         String   @id @default(cuid())
  deliveryId String
  name       String
  url        String   @db.Text
  size       Int?
  createdAt  DateTime @default(now())
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model DeliveryPiece {
  id         String   @id @default(cuid())
  deliveryId String
  pieceId    String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  piece      Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  @@unique([deliveryId, pieceId])
}

model MediaFormat {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  vehicle   String?
  media     String?
  format    String?
  // width/height em PX (calculado a partir de widthValue/heightValue + unit + dpi).
  // Mantido em px pra compatibilidade com geracao de pecas, canvas, etc.
  width     Int
  height    Int
  // Valores originais na unidade escolhida (cm, mm, inch, pt, pc, px).
  // Sem isso, ao editar um formato cadastrado em cm, teriamos que adivinhar
  // a unidade original a partir do px.
  widthValue  Float?
  heightValue Float?
  widthUnit   String? @default("px") @db.VarChar(8)
  heightUnit  String? @default("px") @db.VarChar(8)
  dpi       Int?
  category  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}
