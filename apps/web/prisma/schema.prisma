generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String        @id @default(cuid())
  name                  String
  slug                  String        @unique
  // White-label: campos sobrescrevem branding default (ZZOSY/amarelo/SUNO logos)
  // em TopNav, apresentacao web e PPTX exportado. Null = usa defaults.
  /// Campos `brand*` no Tenant sao do WHITE-LABEL do SaaS (substituem o
  /// branding default ZZOSY na TopNav/apresentacao/PPTX). NAO confundir com
  /// Client.brand* (que e a marca do cliente final). `whiteLabelAccentColor`
  /// foi renomeado de `brandPrimaryColor` (audit F6.2) pra desambiguar.
  brandName             String?
  brandLogoUrl          String?       @db.LongText
  brandSecondaryLogoUrl String?       @db.LongText
  whiteLabelAccentColor String?       @map("brandPrimaryColor") @db.VarChar(16)
  brandFooterText       String?
  /// Taxonomia compartilhada: 3 listas globais ao tenant (segments, categories,
  /// filters). Aplicaveis a TODA entidade do ZZOSY (clientes, campanhas, pecas,
  /// midias). Auto-merge: valores criados em qualquer entidade sao appended
  /// aqui sem duplicar.
  taxonomy              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  users                 User[]
  clients               Client[]
  mediaFormats          MediaFormat[]
}

model User {
  id         String     @id @default(cuid())
  tenantId   String
  name       String?
  email      String     @unique
  password   String
  role       String     @default("ADMIN")
  blocked    Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  accounts   Account[]
  sessions   Session[]
  deliveries Delivery[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id                  String                         @id @default(cuid())
  tenantId            String
  name                String
  slug                String?
  contact             String?
  email               String?
  phone               String?
  address             String?
  /// Renomeado de `logoUrl` (F6.1) pra alinhar com Tenant.brandLogoUrl. Sem
  /// migration de coluna — usa @map pra preservar o nome fisico no banco.
  brandLogoUrl        String?                        @map("logoUrl") @db.LongText
  brandFont           String?
  brandColors         Json?
  /// 4 presets tipograficos: { titulo, subtitulo, body, legenda }
  /// Cada um: { fontWeight: 100-900, fontSize: number em pt }
  brandTypography     Json?
  /// @deprecated substituido por customFontFiles. Coluna mantida pra evitar
  /// migration destrutiva — sem leitura/escrita ativa em codigo (audit F5.1).
  customFontUrl       String?                        @db.LongText
  customFontFiles     Json?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  tenant              Tenant                         @relation(fields: [tenantId], references: [id])
  campaigns           Campaign[]
  libraryAssets       ClientLibraryAsset[]
  librarySmartObjects ClientLibrarySmartObjectFile[]
}

model Campaign {
  id           String            @id @default(cuid())
  name         String
  code         String?           @db.VarChar(64)
  clientId     String
  status       String            @default("STANDBY")
  psdUrl       String?           @db.Text
  psdName      String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assets       CampaignAsset[]
  keyVision    KeyVision?
  pieces       Piece[]
  deliveries   Delivery[]
  smartObjects SmartObjectFile[]
}

model CampaignAsset {
  id                   String              @id @default(cuid())
  campaignId           String
  type                 String              @default("TEXT")
  label                String
  content              String?             @db.LongText
  value                String?             @db.Text
  imageUrl             String?             @db.LongText
  // lastOverride: JSON com o ultimo template visual aplicado na MATRIZ
  // (cor, fonte, tamanho, etc). Quando o asset e adicionado de novo no canvas
  // ou via swap, vem com esse template. Pecas nao atualizam esse campo.
  lastOverride         Json?
  order                Int                 @default(0)
  posX                 Float               @default(100)
  posY                 Float               @default(100)
  scaleX               Float               @default(1)
  scaleY               Float               @default(1)
  rotation             Float               @default(0)
  width                Int                 @default(600)
  visible              Boolean             @default(true)
  smartObjectId        String?
  // GAM: instancia de um ClientLibraryAsset (modelo Figma).
  // libraryAssetId    = FK pra o asset main no library do cliente
  // libraryAssetVersion = versao do library ao instanciar; quando library.version > este,
  //                       UI mostra "Update available"
  // libraryAssetDetached = user clicou Detach → asset vira independente
  // slotKey            = chave de match em cartridges (herdada do library OU manual)
  libraryAssetId       String?             @db.VarChar(30)
  libraryAssetVersion  Int?
  libraryAssetDetached Boolean?            @default(false)
  slotKey              String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  campaign             Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  smartObject          SmartObjectFile?    @relation(fields: [smartObjectId], references: [id], onDelete: SetNull)
  libraryAsset         ClientLibraryAsset? @relation(fields: [libraryAssetId], references: [id], onDelete: SetNull)

  @@index([smartObjectId])
  @@index([libraryAssetId])
  @@index([slotKey])
}

// GAM — biblioteca de assets por cliente (modelo Figma main component).
// Sobrevive a apagar campanhas. Editar = propaga pra instancias com libraryAssetId=X.
model ClientLibraryAsset {
  id            String                        @id @default(cuid())
  clientId      String
  name          String // user-defined ("Logo Sicredi Branco")
  slotKey       String? // "logo-primary", "headline-text" — match em cartridges
  type          String // TEXT, IMAGE, SHAPE, SMART_OBJECT
  content       String?                       @db.LongText
  lastOverride  Json?
  imageUrl      String?                       @db.LongText
  thumbnailUrl  String?                       @db.LongText
  smartObjectId String?
  tags          Json? // ["logo", "marca-principal", ...]
  notes         String?                       @db.Text
  meta          Json? // dimensoes, cores, qualquer metadata extra
  version       Int                           @default(1) // bump em cada PUT content; instances usam pra Update detection
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt
  createdBy     String? // userId
  client        Client                        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  smartObject   ClientLibrarySmartObjectFile? @relation(fields: [smartObjectId], references: [id], onDelete: SetNull)
  instances     CampaignAsset[]

  @@index([clientId, type])
  @@index([clientId, updatedAt])
  @@index([slotKey])
}

// Mirror de SmartObjectFile mas vinculado a Client (nao Campaign).
// Bytes embedded (PSB/AI/PDF/PNG/JPG) sobrevivem a apagar campanhas. Round-trip
// com PSD preservado via cartridge .zzosy export/import.
model ClientLibrarySmartObjectFile {
  id            String               @id @default(cuid())
  clientId      String
  guid          String               @db.VarChar(64)
  filePath      String               @db.LongText
  mime          String               @db.VarChar(100)
  originalName  String               @db.VarChar(500)
  sizeBytes     Int
  width         Int?
  height        Int?
  createdAt     DateTime             @default(now())
  client        Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  libraryAssets ClientLibraryAsset[]

  @@index([clientId])
  @@index([guid])
}

// Smart Object embeddado em PSD (linkedFile). Preserva os bytes originais
// pra round-trip ZZOSY → Photoshop → ZZOSY sem perda. 1 SO pode ser reusado
// por varios CampaignAsset (mesmo logo em multiplos layers, por exemplo).
model SmartObjectFile {
  id           String          @id @default(cuid())
  campaignId   String
  guid         String          @db.VarChar(64)
  filePath     String          @db.LongText
  mime         String          @db.VarChar(100)
  originalName String          @db.VarChar(500)
  sizeBytes    Int
  width        Int?
  height       Int?
  createdAt    DateTime        @default(now())
  campaign     Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assets       CampaignAsset[]

  @@index([campaignId])
  @@index([guid])
}

model KeyVision {
  id           String   @id @default(cuid())
  campaignId   String   @unique
  data         String?  @db.LongText
  bgColor      String   @default("#ffffff")
  layers       String?  @db.LongText
  width        Int      @default(1920)
  height       Int      @default(1080)
  thumbnailUrl String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Piece {
  id            String          @id @default(cuid())
  campaignId    String
  mediaFormatId String?
  name          String?
  segment       String?         @db.VarChar(255)
  copy          String?         @db.LongText
  status        String          @default("STANDBY")
  data          String?         @db.LongText
  /// Render exportavel (PNG/JPG da peca em resolucao max). Antes este campo
  /// fazia dobro como imageUrl + thumbnail; agora `thumbnailUrl` carrega a
  /// preview/lista e imageUrl fica reservado pro export final.
  imageUrl      String?         @db.LongText
  /// Preview pequena (max 1920px maior lado) usada na lista, presentation e
  /// PPTX. Separada de imageUrl pra evitar overload do mesmo campo. Vazia em
  /// pieces antigas — populada no proximo save no editor.
  thumbnailUrl  String?         @db.LongText
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deliveries    DeliveryPiece[]
}

model Delivery {
  id            String          @id @default(cuid())
  campaignId    String
  name          String?
  /// Valores: PENDENTE (default na criacao), ENVIADA (apos POST entregar).
  /// PT (F6.3) — alinha com Piece.status. Tinha PENDING/SENT antes da migration.
  status        String          @default("PENDENTE")
  notes         String?         @db.Text
  zipUrl        String?         @db.Text
  zipSize       Int?
  deliveredById String?
  formats       String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deliveredBy   User?           @relation(fields: [deliveredById], references: [id])
  files         DeliveryFile[]
  pieces        DeliveryPiece[]
}

model DeliveryFile {
  id         String   @id @default(cuid())
  deliveryId String
  name       String
  url        String   @db.Text
  size       Int?
  createdAt  DateTime @default(now())
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model DeliveryPiece {
  id         String   @id @default(cuid())
  deliveryId String
  pieceId    String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  piece      Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@unique([deliveryId, pieceId])
}

model MediaFormat {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  vehicle     String?
  media       String?
  format      String?
  // width/height em PX (calculado a partir de widthValue/heightValue + unit + dpi).
  // Mantido em px pra compatibilidade com geracao de pecas, canvas, etc.
  width       Int
  height      Int
  // Valores originais na unidade escolhida (cm, mm, inch, pt, pc, px).
  // Sem isso, ao editar um formato cadastrado em cm, teriamos que adivinhar
  // a unidade original a partir do px.
  widthValue  Float?
  heightValue Float?
  widthUnit   String?  @default("px") @db.VarChar(8)
  heightUnit  String?  @default("px") @db.VarChar(8)
  dpi         Int?
  category    String?
  segment     String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
}
