# ─── BANCO DE DADOS ─────────────────────────────────────────────
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/zzosy"

# ─── NEXTAUTH ────────────────────────────────────────────────────
NEXTAUTH_SECRET="gere-um-secret-aleatorio-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ─── STRIPE BILLING ──────────────────────────────────────────────
# Sem essas envs, /plans page funciona mas checkout falha. Setup:
#  1. Criar conta em stripe.com + ativar (PIX/BRL: precisa Stripe Brasil)
#  2. Criar Products Pro + Agency em dashboard.stripe.com/products
#     - Preço Pro mensal R$ 99 → copia price_xxx
#     - Preço Agency mensal R$ 299 → copia price_xxx
#  3. Webhook endpoint: https://app.zzosy.com/api/webhooks/stripe
#     events: checkout.session.completed, customer.subscription.*,
#             invoice.payment_succeeded, invoice.payment_failed
#  4. Copia STRIPE_WEBHOOK_SECRET do dashboard
#  5. Roda `npx tsx scripts/seed-plans.ts` UMA vez pra popular Plan rows
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."        # Price ID do plano Pro mensal
STRIPE_PRICE_AGENCY="price_..."     # Price ID do plano Agency mensal
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── CLOUDFLARE R2 (storage) ─────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="zzosy-assets"
R2_PUBLIC_URL=""

# ─── RATE LIMITING (Upstash Redis REST) ──────────────────────────
# Sem essas envs, rate limit fica no-op (so warn no boot). Em prod: OBRIGATORIO.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── SENTRY (error tracking) ─────────────────────────────────────
# Sem DSN, Sentry SDK fica no-op. Crie projeto em https://sentry.io/signup/
# Mesma DSN nas duas vars — server vs client expose ao bundle navegador.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ─── EMAIL (Resend) ──────────────────────────────────────────────
# Sem RESEND_API_KEY, sendEmail() loga + retorna sem enviar (dev mode).
# Crie conta em https://resend.com/signup + verifique seu dominio.
# EMAIL_FROM deve usar um dominio verificado no Resend (ex: noreply@seudominio.com)
RESEND_API_KEY=""
EMAIL_FROM="ZZOSY <noreply@zzosy.com>"

# ─── LOGS ────────────────────────────────────────────────────────
# Default: info. Use "debug" pra mais verbosidade em prod (caro em quota).
LOG_LEVEL="info"

# ─── APP ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ZZOSY"
